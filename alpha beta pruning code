MAX = 1000
MIN = -1000

def alphabeta(depth, node, isMax, values, alpha, beta):

    # Leaf node
    if depth == 3:
        return values[node]

    if isMax:
        best = MIN

        for i in range(2):
            value = alphabeta(depth + 1, node * 2 + i, False, values, alpha, beta)
            best = max(best, value)
            alpha = max(alpha, best)

            if alpha >= beta:
                break

        return best

    else:
        best = MAX

        for i in range(2):
            value = alphabeta(depth + 1, node * 2 + i, True, values, alpha, beta)
            best = min(best, value)
            beta = min(beta, best)

            if alpha >= beta:
                break

        return best


values = [3, 5, 6, 9, 1, 2, 0, -1]

print("Optimal Value:", alphabeta(0, 0, True, values, MIN, MAX))
